# Normalize line endings to LF in the repository for all text files.
# Windows checkouts will still use CRLF locally if core.autocrlf=true,
# but the repo itself stays consistent.
* text=auto eol=lf

# Explicitly keep these as LF (Android/Gradle tooling expects LF)
*.kt        text eol=lf
*.kts       text eol=lf
*.xml       text eol=lf
*.gradle    text eol=lf
*.properties text eol=lf
*.md        text eol=lf
*.json      text eol=lf
*.toml      text eol=lf
*.pro       text eol=lf
*.txt       text eol=lf

# Binary files — never touch line endings
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.webp      binary
*.keystore  binary
*.jks       binary
